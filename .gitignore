# Cargo build output
/target/

# Rustfmt backups
**/*.rs.bk

# IntelliJ / JetBrains IDEs
.idea/

# macOS
.DS_Store

# Web frontend (the web/ subtree has its own .gitignore for finer control)
web/node_modules/
web/dist/
web/.wrangler/
web/.dev.vars

# Generated HTML pages and data — produced by web/scripts/gen-*.ts at build time.
# Do not commit these; npm run dev / build regenerates them.
web/zh/
web/en/
web/ja/
web/index.html
web/src/data/cameras.json
