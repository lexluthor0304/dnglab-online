{
  "name": "neoanaloglab-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "bash ../scripts/build-wasm.sh",
    "gen:cameras": "tsx scripts/gen-cameras.ts",
    "gen:pages": "tsx scripts/gen-pages.ts",
    "gen:sitemap": "tsx scripts/gen-sitemap.ts",
    "gen": "npm run gen:cameras && npm run gen:pages",
    "dev": "npm run gen && vite",
    "build": "npm run wasm && npm run gen && vite build && npm run gen:sitemap",
    "build:ci": "npm run gen && vite build && npm run gen:sitemap",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "rawler-wasm": "file:../wasm/pkg"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^3.90.0"
  }
}
